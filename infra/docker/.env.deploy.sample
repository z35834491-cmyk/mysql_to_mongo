# 复制为 .env.deploy 后由 Compose 加载（.env.deploy 已加入 .gitignore 勿提交密钥）
#   cp infra/docker/.env.deploy.sample infra/docker/.env.deploy
# 推荐改用向导生成:
#   ./scripts/oneclick-deploy.sh
#
DJANGO_SECRET_KEY=unsafe-local-dev-replace-with-openssl-rand-base64-48
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://127.0.0.1:5173,http://localhost:5173
PUBLIC_URL=http://localhost:8000
PYTHONUNBUFFERED=1
